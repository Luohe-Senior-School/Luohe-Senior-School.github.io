96%87%E5%8C%96%E8%8A%82%E9%A2%84%E5%A4%87/#_3","title":"\u672c\u6b21\u8fd0\u52a8\u4f1a\u8981\u6c42","text":"<p>\u636e\u67d0\u4f4d\u73ed\u4e3b\u4efb\u7684\u4fe1\u606f\uff0c\u672c\u6b21\u8fd0\u52a8\u4f1a\u8981\u6c42\u7981\u6b62 \u4e00\u5207\u5f62\u5f0f\u7684\u5916\u56fd\u6587\u5316\u5143\u7d20\u5c55\u73b0\u5f62\u5f0f \uff08\u5305\u62ec Cosplay\u3001\u5947\u88c5\u5f02\u670d\u4ee5\u53ca\u6f14\u5531\u76f8\u5173\u5185\u5bb9\uff09\uff0c\u5e76\u4e14\u5f00\u4f1a\u591a\u6b21\u5f3a\u8c03\u6b64\u4e8b\uff0c\u5bf9\u6b64\u7ed9\u51fa\u7684\u56de\u7b54\u662f \u6700\u8fd1\u8fd9\u4e00\u6bb5\u7684\u65f6\u5c40\u60c5\u51b5\u4f60\u4eec\u90fd\u77e5\u9053\u3002\u8fd9\u76f8\u6bd4\u4e8e\u53bb\u5e74\u662f\u6700\u5927\u7684\u4e00\u5904\u89c4\u5219\u6539\u52a8\uff0c\u5e76\u4e14\u8981\u6c42\u4e86\u4eca\u5e74\u7684\u5165\u573a \u8981\u6574\u9f50\u3001\u8981\u7cbe\u6c14\u795e \u800c\u4e0d\u662f\u522b\u7684\u5404\u79cd\u82b1\u91cc\u80e1\u54e8\u3002</p> <p>\u5176\u4ed6\u89c4\u5219\u57fa\u672c\u4e0e\u5f80\u5e74\u76f8\u5dee\u4e0d\u5927\uff0c\u5728\u6b64\u4e0d\u518d\u8d58\u8ff0\u3002</p>","tags":["\u5317\u6821\u533a","\u9ad8\u4e8c","\u4e00\u90e8"]},{"location":"blog/2025/04/26/%E4%BD%93%E8%82%B2%E8%BF%90%E5%8A%A8%E6%96%87%E5%8C%96%E8%8A%82%E9%A2%84%E5%A4%87/#_4","title":"\u5173\u4e8e\u672c\u6b21\u6f14\u5531\u4f1a","text":"<p>\u4eca\u5e74\u7684\u6f14\u5531\u4f1a\u4e5f\u6709\u8bb8\u591a\u6539\u53d8\uff0c\u5982\u672c\u6b21\u7684\u5408\u5531\u578b\u8282\u76ee\u7ecf\u8fc7 \u7b5b\u9009 \u4ec5\u4fdd\u7559\u4e86\u4e09\u4e2a\uff0c\u5e76\u4e14\u56e0\u4e3a \u76f8\u5173\u8bbe\u5907\u4f7f\u7528 \u7684\u539f\u56e0\u88ab\u8981\u6c42\u8fdb\u884c\u5408\u5531\u7684\u73ed\u7ea7\u6bcf\u73ed\u7f34\u7eb3\u5171\u8ba1 300 \u4eba\u6c11\u5e01\uff0c\u4e14\u6ca1\u6709\u5408\u5531\u68af\uff1b\u5f53\u7136\uff0c\u6f14\u51fa\u5185\u5bb9\u548c\u8fd0\u52a8\u4f1a\u7684\u8981\u6c42\u4e00\u6837\uff0c\u7981\u6b62\u4e86\u56fd\u5916\u6587\u5316\u5143\u7d20\u76f8\u5173\u5185\u5bb9\u7684\u6f14\u51fa\u3002</p> <p>\u4ee5\u4e0a\u4fe1\u606f\u5747\u6765\u81ea\u67d0\u73ed\u4e3b\u4efb\u4f20\u8fbe\uff0c\u53ef\u80fd\u4f1a\u4e0e\u4e0a\u7ea7\u9886\u5e26\u539f\u8bdd\u6709\u6240\u51fa\u5165\u3002</p> <p>\u4ee5\u4e0a\u4fe1\u606f\u548c\u6307\u793a\u5e94\u8be5\u4f5c\u7528\u4e8e \u5317\u6821\u533a\u9ad8\u4e8c\u4e00\u90e8\u3002</p>","tags":["\u5317\u6821\u533a","\u9ad8\u4e8c","\u4e00\u90e8"]},{"location":"blog/2026/04/28/%E4%BD%93%E8%82%B2%E6%96%87%E5%8C%96%E8%8A%82%E5%87%86%E5%A4%87/","title":"\u4f53\u80b2\u6587\u5316\u8282\uff0c\u51c6\u5907\uff01","text":"","tags":["\u9ad8\u4e8c","\u5317\u6821\u533a"]},{"location":"blog/2026/04/28/%E4%BD%93%E8%82%B2%E6%96%87%E5%8C%96%E8%8A%82%E5%87%86%E5%A4%87/#_1","title":"\u4f53\u80b2\u6587\u5316\u8282\uff0c\u51c6\u5907\uff01","text":"<p>\u4eca\u65e5\u6211\u6821\u4e8e\u4e0b\u5348 19:30 \u8fdb\u884c\u4e86\u5165\u573a\u4eea\u5f0f\u548c\u8dd1\u64cd\u5f69\u6392\u3002</p> <p>\u6574\u4f53\u6765\u770b\uff0c\u4ec5\u8dd1\u64cd\u5f69\u6392\u8fc7\u7a0b\u4e2d\u6bd4\u8f83\u6df7\u4e71\uff0c\u5176\u4e2d\u9ad8\u4e8c\u4e00\u90e8\u6240\u6709\u53c2\u52a0\u73ed\u7ea7\u56e0\u4e3a\u7b2c\u4e00\u6b21\u97f3\u4e50\u901f\u5ea6\u4e0d\u6b63\u5e38\u52a0\u4e0a\u6700\u540e\u505c\u6b62\u4f4d\u7f6e\u4e0d\u5230\u4f4d\u8981\u6c42\u91cd\u8dd1\u4e00\u904d\uff0c\u5f15\u8d77\u4f17\u591a\u5b66\u751f\u53cd\u611f\u3002</p> <p>\u5f69\u6392\u7ed3\u675f\u540e\u73ed\u4e3b\u4efb\u8981\u6c42\u5b66\u751f\u660e\u5929\uff0829\u65e5\uff09\u65e9\u4e0a\u8981\u5728 6:20 \u524d\u5230\u73ed\u3002</p>","tags":["\u9ad8\u4e8c","\u5317\u6821\u533a"]},{"location":"school_archive/about_school/","title":"\u6f2f\u6cb3\u9ad8\u4e2d","text":""},{"location":"school_archive/about_school/#_1","title":"\u6f2f\u6cb3\u9ad8\u4e2d","text":""},{"location":"school_archive/about_school/#_2","title":"\u5f15\u8a00","text":"<p>\u5bf9\u4e8e\u672c\u5b66\u6821\uff0c\u5b98\u65b9\u662f\u8fd9\u6837\u4ecb\u7ecd\u7684</p> <p>\u6f2f\u6cb3\u9ad8\u4e2d\u521b\u5efa\u4e8e1948\u5e74\uff0c\u662f\u6cb3\u5357\u7701\u9996\u6279\u793a\u8303\u6027\u9ad8\u4e2d\uff0c\u5b66\u6821\u603b\u9762\u79ef533\u4ea9\uff08\u542b\u65b0\u6821\u533a\uff09\u3002\u7ecf\u8fc7\u51e0\u5341\u5e74\u7684\u53d1\u5c55\uff0c\u5b66\u6821\u5df2\u6210\u4e3a\u4e00\u6240\u6559\u98ce\u4e25\u8c28\u3001\u5b66\u98ce\u7eaf\u6b63\u3001\u529e\u5b66\u7406\u5ff5\u79d1\u5b66\u3001\u6821\u56ed\u73af\u5883\u4f18\u7f8e\u3001\u6559\u5b66\u8bbe\u65bd\u5148\u8fdb\u3001\u6559\u5e08\u6c34\u5e73\u4e00\u6d41\u3001\u9ad8\u8003\u6210\u7ee9\u8f89\u714c\u3001\u5468\u8fb9\u53bf\u5e02\u8398\u8398\u5b66\u5b50\u68a6\u5bd0\u4ee5\u6c42\u7684\u6210\u624d\u6bbf\u5802\u3002</p> <p>\u6f2f\u6cb3\u9ad8\u4e2d\u73b0\u6709\u5728\u6821\u751f7000\u4f59\u4eba\uff0c\u6559\u804c\u5de5470\u4eba\uff0c\u4e13\u804c\u6559\u5e08\u5168\u90e8\u4e3a\u5927\u5b66\u672c\u79d1\u4ee5\u4e0a\u5b66\u5386\u3002\u5176\u4e2d\u7279\u7ea7\u6559\u5e083\u4eba\uff0c\u56fd\u5bb6\u7ea7\u540d\u5e081\u4eba\uff0c\u4e2d\u539f\u540d\u5e081\u4eba\uff0c\u56fd\u5bb6\u7ea7\u9aa8\u5e72\u6559\u5e082\u4eba\uff0c\u6559\u80b2\u90e8\u516c\u6d3e\u7559\u82f1\u5b66\u80054\u4eba\uff0c\u7701\u6559\u80b2\u6559\u5b66\u4e13\u5bb61\u4eba\uff0c\u7701\u6559\u5e08\u6559\u80b2\u4e13\u5bb62\u4eba\uff0c\u7701\u7ea7\u5b66\u79d1\u5e26\u5934\u4eba6\u4eba\uff0c\u7701\u7ea7\u9aa8\u5e72\u6559\u5e087\u4eba\uff0c\u9ad8\u7ea7\u6559\u5e08121\u4eba\uff0c\u62e5\u6709\u7814\u7a76\u751f\u5b66\u5386\u8005\u8fbe86\u4eba\uff0c\u5e02\u7ea7\u4f18\u79c0\u73ed\u4e3b\u4efb196\u4eba\uff0c\u5e02\u7ea7\u4f18\u79c0\u6559\u5e08252\u4eba\u3002</p> <p>\u6f2f\u6cb3\u9ad8\u4e2d\u62e5\u6709\u6807\u51c6\u5316\u7406\u5316\u751f\u5b9e\u9a8c\u5ba4\u3001\u6807\u51c6\u5316\u8fd0\u52a8\u573a\u548c\u4f53\u80b2\u9986\uff0c\u56fe\u4e66\u9986\u85cf\u4e6612\u4e07\u4f59\u518c\uff0c\u6709\u5b66\u751f\u5bbf\u820d\u697c9\u680b\uff0c\u8bbe2\u4eba\u30014\u4eba\u30016\u4eba\u95f4\u3002\u5357\u5317\u6821\u533a\u5404\u62e5\u6709\u4e00\u680b\u6cb3\u5357\u7701AAA\u7ea7\u5b66\u751f\u9910\u5385\u3002\u65b0\u6821\u533a\u6559\u5ba4\u5185\u88c5\u6709\u7a7a\u8c03\u3002\u6f2f\u6cb3\u9ad8\u4e2d\u5148\u8fdb\u5b8c\u5584\u7684\u6559\u80b2\u6559\u5b66\u8bbe\u65bd\u4e3a\u5b66\u751f\u6210\u624d\u521b\u9020\u4e86\u4f18\u826f\u7684\u6761\u4ef6\u3002</p> <p>\u516d\u5341\u4e09\u5e74\u7684\u63a2\u7d22\u548c\u8ffd\u6c42\uff0c\u6f2f\u6cb3\u9ad8\u4e2d\u82f1\u624d\u8f88\u51fa\uff0c\u7fa4\u661f\u7480\u74a8\u3002\u4ece\u6f2f\u9ad8\u8d70\u51fa\u8fc7\u539f\u4e2d\u592e\u653f\u6cbb\u5c40\u59d4\u5458\u3001\u4e2d\u592e\u519b\u59d4\u526f\u4e3b\u5e2d\u3001\u56fd\u52a1\u59d4\u5458\u517c\u56fd\u9632\u90e8\u957f\u66f9\u521a\u5ddd\u4e0a\u5c06\uff0c\u4e2d\u592e\u59d4\u5458\u3001\u603b\u540e\u52e4\u90e8\u526f\u90e8\u957f\u79e6\u94f6\u6cb3\u5c06\u519b\uff0c\u4e2d\u56fd\u77ff\u4e1a\u5927\u5b66\u5e38\u52a1\u526f\u6821\u957f\u3001\u957f\u6c5f\u5b66\u8005\u8d75\u8dc3\u6c11\u6559\u6388\uff0c\u53cc\u6c47\u96c6\u56e2\u8463\u4e8b\u957f\u4e07\u9686\u7b49\u515a\u653f\u519b\u9886\u5bfc\u4eba\u548c\u5546\u4e1a\u7cbe\u82f1\u3002\u4ec590\u5e74\u4ee3\u4ee5\u6765\uff0c\u6f2f\u6cb3\u9ad8\u4e2d\u5386\u5c4a\u6bd5\u4e1a\u751f\u4e2d\uff0c\u83b7\u5f97\u535a\u58eb\u5b66\u4f4d\u7684\u5c31\u8fbe388\u4eba\uff0c\u516c\u6d3e\u51fa\u56fd\u5b66\u8005\u8fbe198\u4eba\u4e4b\u591a\u3002\u6f2f\u6cb3\u9ad8\u4e2d\u529e\u5b66\u6210\u7ee9\u5353\u8457\uff0c\u5907\u53d7\u793e\u4f1a\u5173\u6ce8\uff0c\u4e2d\u79d1\u5927\u3001\u5409\u6797\u5927\u5b66\u3001\u5357\u4eac\u7406\u5de5\u3001\u897f\u5317\u5de5\u5927\u3001\u4e2d\u56fd\u77ff\u4e1a\u5927\u5b66\u3001\u90d1\u5dde\u5927\u5b66\u3001\u89e3\u653e\u519b\u5916\u56fd\u8bed\u5b66\u9662\u7b49\u5168\u56fd\u91cd\u70b9\u9662\u6821\u90fd\u628a\u6f2f\u6cb3\u9ad8\u4e2d\u8bbe\u7acb\u4e3a\u751f\u6e90\u57fa\u5730\u3002</p> <p>\u7531\u4e8e\u529e\u5b66\u6210\u7ee9\u7a81\u51fa\uff0c\u5f15\u9886\u6559\u80b2\u65b9\u5411\uff0c\u6f2f\u6cb3\u9ad8\u4e2d\u591a\u6b21\u83b7\u5f97\u56fd\u5bb6\u3001\u90e8\u3001\u7701\u7ea7\u8868\u5f70\uff0c\u8fd1\u51e0\u5e74\u5b66\u6821\u5148\u540e\u88ab\u8bc4\u4e3a\u5168\u56fd\u5e08\u5fb7\u5efa\u8bbe\u5148\u8fdb\u5355\u4f4d\uff0c\u5168\u56fd\u4fe1\u606f\u5316\u5efa\u8bbe\u5148\u8fdb\u5355\u4f4d\uff0c\u5168\u56fd\u6821\u56ed\u6587\u5316\u5efa\u8bbe\u5148\u8fdb\u5355\u4f4d\uff0c\u5168\u56fd\u6559\u80b2\u79d1\u5b66\u89c4\u5212\u6559\u80b2\u90e8\u4f18\u79c0\u79d1\u7814\u57fa\u5730\uff0c\u5168\u56fd\u4e94\u56db\u7ea2\u65d7\u56e2\u59d4\uff0c\u6cb3\u5357\u7701\u9996\u6279\u793a\u8303\u6027\u9ad8\u4e2d\uff0c\u6cb3\u5357\u7701\u536b\u751f\u5148\u8fdb\u5355\u4f4d\uff0c\u6cb3\u5357\u7701\u5316\u5b66\u6559\u5b66\u79d1\u7814\u57fa\u5730\u5b66\u6821\uff0c\u6cb3\u5357\u7701\u4f9d\u6cd5\u6cbb\u6821\u5148\u8fdb\u5355\u4f4d\uff0c\u88ab\u4eba\u4e8b\u90e8\u3001\u6559\u80b2\u90e8\u8bc4\u4e3a\u6559\u80b2\u7cfb\u7edf\u5148\u8fdb\u96c6\u4f53\u3002</p> <p>\u4fe1\u606f\u6458\u81ea\u6b64\u5904</p>"},{"location":"school_archive/about_school/#_3","title":"\u6b63\u6587","text":""},{"location":"school_archive/buildings/","title":"\u5efa\u7b51","text":""},{"location":"school_archive/buildings/#_1","title":"\u5efa\u7b51","text":"<p>\u5728\u6b64\u5904\uff0c\u6211\u4eec\u5c06\u4f1a\u516c\u5e03\u6f2f\u9ad8\u6821\u5185\u7684\u4e00\u4e9b\u5efa\u7b51\u7269\u4fe1\u606f</p>"},{"location":"school_archive/class/","title":"\u73ed\u7ea7\u4fe1\u606f","text":""},{"location":"school_archive/class/#_1","title":"\u73ed\u7ea7\u4fe1\u606f","text":"<p>\u5728\u6b64\u5904\uff0c\u6211\u4eec\u5c06\u4f1a\u516c\u5e03\u6f2f\u9ad8\u5bf9\u4e8e\u73ed\u7ea7\u7684\u5212\u5206\u60c5\u51b5\u53ca\u5176\u4fe1\u606f</p>"},{"location":"school_archive/class/grade1/","title":"\u9ad8\u4e00","text":""},{"location":"school_archive/class/grade1/#_1","title":"\u9ad8\u4e00","text":"<p>\u6f2f\u9ad8\u7684\u9ad8\u4e00\u5927\u81f4\u5206\u4e3a\u4e09\u4e2a\u73ed\uff1a\u6e05\u5317\u73ed\uff0c\u5b8f\u5fd7\u73ed\uff0c\u666e\u901a\u73ed</p>"},{"location":"school_archive/class/grade1/#_2","title":"\u6e05\u5317\u73ed","text":""},{"location":"school_archive/class/grade1/#_3","title":"\u5b8f\u5fd7\u73ed","text":""},{"location":"school_archive/class/grade1/#_4","title":"\u666e\u901a\u73ed","text":""},{"location":"school_archive/class/grade2/","title":"\u9ad8\u4e8c","text":""},{"location":"school_archive/class/grade2/#_1","title":"\u9ad8\u4e8c","text":""},{"location":"school_archive/class/grade3/","title":"\u9ad8\u4e09","text":""},{"location":"school_archive/class/grade3/#_1","title":"\u9ad8\u4e09","text":""},{"location":"school_archive/non_teacher/","title":"\u804c\u5de5","text":""},{"location":"school_archive/non_teacher/#_1","title":"\u804c\u5de5","text":"<p>\u5728\u6b64\u5904\uff0c\u6211\u4eec\u5c06\u4f1a\u516c\u5e03\u6f2f\u9ad8\u5185\u7684\u4e00\u4e9b\u975e\u6559\u5e08\u4eba\u5458\u7684\u4fe1\u606f</p>"},{"location":"school_archive/teacher/","title":"\u6559\u5e08","text":""},{"location":"school_archive/teacher/#_1","title":"\u6559\u5e08","text":"<p>\u5728\u6b64\u5904\uff0c\u6211\u4eec\u5c06\u4f1a\u516c\u5e03\u6f2f\u9ad8\u5185\u7684\u4e00\u4e9b\u6559\u5e08\u4eba\u5458\u7684\u4fe1\u606f</p>"},{"location":"blog/archive/2026/","title":"2026","text":""},{"location":"blog/archive/2026/#2026","title":"2026","text":""},{"location":"blog/archive/2025/","title":"2025","text":""},{"location":"blog/archive/2025/#2025","title":"2025","text":""}]}